[Unit]
Description=Project Istari Builder Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=istari
Group=istari
WorkingDirectory=/srv/project-istari
EnvironmentFile=/etc/project-istari/backend.env
ExecStart=/srv/project-istari/venv/bin/gunicorn --bind 127.0.0.1:8000 --workers 1 --threads 4 --timeout 120 src.builder_api:app
Restart=on-failure
RestartSec=5
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/srv/project-istari/data

[Install]
WantedBy=multi-user.target
